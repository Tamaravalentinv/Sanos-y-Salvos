# Sanos y Salvos - Environment Configuration Template
# IMPORTANTE: Copiar este archivo a .env y llenar con valores reales
# NEVER commit .env file - it contains sensitive credentials

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=sanosuser
MYSQL_PASSWORD=sanospass123

# Application Profiles
SPRING_PROFILES_ACTIVE=docker

# MS Usuarios
USUARIOS_DB_URL=jdbc:mysql://mysql:3306/sanosysalvos_usuarios
USUARIOS_DB_USER=sanosuser
USUARIOS_DB_PASSWORD=sanospass123

# MS Reportes
REPORTES_DB_URL=jdbc:mysql://mysql:3306/sanosysalvos
REPORTES_DB_USER=sanosuser
REPORTES_DB_PASSWORD=sanospass123

# MS Geolocalizacion
GEO_DB_URL=jdbc:mysql://mysql:3306/sanosysalvos
GEO_DB_USER=sanosuser
GEO_DB_PASSWORD=sanospass123

# MS Coincidencias
COINCIDENCIAS_DB_URL=jdbc:mysql://mysql:3306/sanosysalvos
COINCIDENCIAS_DB_USER=sanosuser
COINCIDENCIAS_DB_PASSWORD=sanospass123

# MS Notificaciones
NOTIFICACIONES_DB_URL=jdbc:mysql://mysql:3306/sanosysalvos_notificaciones
NOTIFICACIONES_DB_USER=sanosuser
NOTIFICACIONES_DB_PASSWORD=sanospass123

# Email Configuration (Optional - for MS Notificaciones)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=86400000

# Logging
LOG_LEVEL=INFO
